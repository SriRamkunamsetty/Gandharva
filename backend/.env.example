# FastAPI Config
PROJECT_NAME="Gandharva"
API_V1_STR="/api/v1"
LOG_LEVEL="INFO"

# Database
DATABASE_URL="postgresql://user:pass@localhost:5432/gandharva"
REDIS_URL="redis://localhost:6379/0"

# Firebase Cloud Persistence
FIREBASE_SERVICE_ACCOUNT_JSON='{"type": "service_account", "project_id": "...", ...}'
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="gandharva-2026.firebasestorage.app"

# AI/ML Pipeline
ENABLE_ML_PIPELINE=True
DEVICE="cpu"
POST_MIN_DURATION=0.1
MERGE_GAP=0.05
CLUSTER_WINDOW=0.05
CLUSTER_RATIO=0.4
